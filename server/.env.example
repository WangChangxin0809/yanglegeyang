# 环境变量配置（开发环境）

# 服务监听地址
SERVER_HOST=0.0.0.0
SERVER_PORT=8089

# MySQL（本项目与金毛大战波斯猫共用一个 MySQL 实例，表名统一用 hd_ 前缀）
# 本地：golden_vs_persian   线上：ai_golden_vs_persian
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=golden_vs_persian

# 微信小程序
WX_APP_ID=
WX_APP_SECRET=

# JWT
JWT_SECRET=please-change-me-in-production
JWT_EXPIRE_HOURS=168

# 阿里云 OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com/

# 线上服务器 SSH（运维脚本远程执行用）
SSH_HOST=
SSH_USER=
SSH_PASSWORD=

# 线上 MySQL root 凭据（phpMyAdmin 登录、运维脚本直连）
MYSQL_ROOT_HOST=
MYSQL_ROOT_USER=
MYSQL_ROOT_PASSWORD=
MYSQL_ROOT_DATABASE=
